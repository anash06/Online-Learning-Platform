# Server Configuration
PORT=8000
HOST=0.0.0.0
ENV=development

# Database Configuration
# In production, use mongodb+srv://username:password@cluster.mongodb.net
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=lms_db

# Security & Authentication (Generate secure keys in production)
JWT_SECRET_KEY=supersecretjwtaccesskeyforonlinelearningplatform2026
JWT_REFRESH_SECRET_KEY=supersecretjwtrefreshkeyforonlinelearningplatform2026
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Razorpay Payment Gateway (Use test mode keys for development)
RAZORPAY_KEY_ID=rzp_test_samplekeyid12345
RAZORPAY_KEY_SECRET=samplesecretkey67890

# File Upload Configuration (Local storage is default, can expand to Cloudinary)
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=10485760  # 10MB in bytes

# Simulated Mail Configuration for Password Reset / OTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=yoursecretmailpassword
